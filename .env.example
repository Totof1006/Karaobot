# Token de ton bot Discord (Portail développeur → Bot → Token)
DISCORD_TOKEN=ton_token_ici

# ID de l'application (Portail développeur → General Information → Application ID)
CLIENT_ID=ton_client_id_ici

# ID de ton serveur Discord (clic droit sur le serveur → Copier l'ID)
GUILD_ID=ton_guild_id_ici
